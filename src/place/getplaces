import requests
import csv
import time
import re
import sys

BASE_URL = "https://www.logainm.ie/api/v1.1/" 
API_KEY = "82NcXbOC6qF6xkRf0eQiNaJe4UqI0W"

TOWNLAND_CATEGORY_ID = "BF"

def safe_get(data_dict, target_key, default_value=None):
    """Safely retrieves a value from a dictionary ignoring case sensitivity."""
    if not isinstance(data_dict, dict):
        return default_value
    for k, v in data_dict.items():
        if k.lower() == target_key.lower():
            return v
    return default_value

def get_name(place_data):
    """Extracts the best available English name from a Logainm place object."""
    name_en = safe_get(place_data, "nameEN") or safe_get(place_data, "defaultName")
    
    if not name_en:
        placenames = safe_get(place_data, "placenames", [])
        for pn in placenames:
            wording = safe_get(pn, "wording", "")
            language = safe_get(pn, "language", "")
            if language == "en" and wording:
                name_en = wording
                break
                
        if not name_en and placenames:
            name_en = safe_get(placenames[0], "wording", "")
            
    return name_en

def extract_geography(place_data):
    """Extracts the primary latitude and longitude coordinates."""
    geo = safe_get(place_data, "geography", {})
    coords = safe_get(geo, "coordinates", [])
    
    if isinstance(coords, list) and len(coords) > 0:
        coords = coords[0]
        
    lat = safe_get(coords, "latitude", "")
    lon = safe_get(coords, "longitude", "")
    
    return lat, lon

def extract_relationships(place_data):
    """Extracts Names and IDs for County, Barony, Civil Parish, and DED."""
    county_name, county_id = "", ""
    barony_name, barony_id = "", ""
    parish_name, parish_id = "", ""
    ded_name, ded_id = "", ""
    
    included_in = safe_get(place_data, "includedIn", [])
    
    for item in included_in:
        category = safe_get(item, "category", {})
        cat_id = str(safe_get(category, "id", "")).upper()
        cat_name = safe_get(category, "nameEN", "").lower()
            
        if cat_id or cat_name:
            item_id = safe_get(item, "id", "")
            item_name = get_name(item)
            
            if cat_id == "CON" or cat_name == "county":
                county_name, county_id = item_name, item_id
            elif cat_id == "BAR" or cat_name == "barony":
                barony_name, barony_id = item_name, item_id
            elif cat_id == "PAR" or cat_name == "civil parish":
                parish_name, parish_id = item_name, item_id
            # Logainm typically uses 'TR' (Toghroinn) for DED internally, but we check 'ED' and the name too
            elif cat_id in ["TR", "ED"] or cat_name == "electoral division":
                ded_name, ded_id = item_name, item_id
            
    return county_name, county_id, barony_name, barony_id, parish_name, parish_id, ded_name, ded_id

def get_place_details(session, place_id):
    """Fetches the full data profile for a specific Logainm ID."""
    endpoint = f"{BASE_URL}{place_id}"
    response = session.get(endpoint)
    response.raise_for_status()
    return response.json()

def get_child_townlands(session, parent_id):
    """Paginates through the API to collect all child townlands for a given Place ID."""
    params = {
        "PlaceID": parent_id, 
        "CategoryID": TOWNLAND_CATEGORY_ID,
        "Page": 1
    }
    townlands = []
    
    while True:
        response = session.get(BASE_URL, params=params)
        response.raise_for_status()
        
        results = safe_get(response.json(), "results", [])
        if not results:
            break
            
        townlands.extend(results)
        if len(results) < 1000: 
            break
            
        params["Page"] += 1
        
    return townlands

def main():
    print("Logainm Townland Extractor")
    search_input = input("Enter the exact numeric Logainm Place ID (e.g., 52): ").strip()
    
    if not search_input.isdigit():
        print("Error: Please provide a valid numeric Logainm ID. Exiting.")
        sys.exit(1)
        
    search_id = search_input
    print(f"\nRetrieving profile for ID: {search_id}")
    
    with requests.Session() as session:
        session.headers.update({
            "Accept": "application/json",
            "X-Api-Key": API_KEY
        })
        
        try:
            parent_info = get_place_details(session, search_id)
            
            parent_name_en = get_name(parent_info)
            display_name = parent_name_en if parent_name_en else search_id
            
            parent_category_obj = safe_get(parent_info, "category", {})
            parent_type = safe_get(parent_category_obj, "nameEN", "unknown")
                
            print(f"Found Target Place: {display_name} ({parent_type})")
            
            print("Retrieving associated townlands...")
            townland_summaries = get_child_townlands(session, search_id)
            total_townlands = len(townland_summaries)
            print(f"Total townlands found: {total_townlands}")
            
            if total_townlands == 0:
                print("No townlands found for this location.")
                sys.exit(0)
            
            safe_filename = re.sub(r'[^\w\-_\. ]', '_', display_name)
            csv_filepath = f"{safe_filename}_{parent_type}_townlands.csv"
            
            print(f"\nDownloading full data and writing to {csv_filepath}...")
            
            with open(csv_filepath, mode='w', newline='', encoding='utf-8-sig') as csv_file:
                writer = csv.writer(csv_file)
                
                writer.writerow([
                    "place_id", "logainm_id", "name_en", "place_type", 
                    "parent_name", "parent_id", "parent_type",
                    "ded_name", "ded_id",
                    "county_name", "county_id", 
                    "barony_name", "barony_id", 
                    "civil_parish_name", "civil_parish_id", 
                    "latitude", "longitude", 
                    "logainm_url", "notes"
                ])
                
                place_id_counter = 1
                
                # Write Parent Row
                d_lat, d_lon = extract_geography(parent_info)
                d_c_name, d_c_id, d_b_name, d_b_id, d_p_name, d_p_id, d_ded_name, d_ded_id = extract_relationships(parent_info)
                parent_url = f"https://www.logainm.ie/en/{search_id}"
                
                writer.writerow([
                    place_id_counter, search_id, parent_name_en, parent_type, 
                    parent_name_en, search_id, parent_type,
                    d_ded_name, d_ded_id,
                    d_c_name, d_c_id, 
                    d_b_name, d_b_id, 
                    d_p_name, d_p_id,
                    d_lat, d_lon, 
                    parent_url, ""
                ])
                place_id_counter += 1
                
                # Write Townland Rows
                for index, t_summary in enumerate(townland_summaries, start=1):
                    t_id = safe_get(t_summary, "id")
                    
                    print(f"Processing {index}/{total_townlands} (ID: {t_id})...", end="\r")
                    t_info = get_place_details(session, t_id)
                    
                    t_name_en = get_name(t_info)
                    t_lat, t_lon = extract_geography(t_info)
                    t_c_name, t_c_id, t_b_name, t_b_id, t_p_name, t_p_id, t_ded_name, t_ded_id = extract_relationships(t_info)
                    t_url = f"https://www.logainm.ie/en/{t_id}"
                    
                    writer.writerow([
                        place_id_counter, t_id, t_name_en, "townland", 
                        parent_name_en, search_id, parent_type,
                        t_ded_name, t_ded_id,
                        t_c_name, t_c_id, 
                        t_b_name, t_b_id, 
                        t_p_name, t_p_id,
                        t_lat, t_lon, 
                        t_url, ""
                    ])
                    place_id_counter += 1
                    
                    time.sleep(0.05) 
                    
            print(f"\nExport complete. File saved to: {csv_filepath}")

        except PermissionError:
            print("\nPermission Error: Ensure you have write access to the current directory.")
        except requests.exceptions.RequestException as e:
            print(f"\nAPI request failed. Verify the Logainm ID is correct. Error details: {e}")
        except Exception as e:
            print(f"\nAn error occurred: {e}")

if __name__ == "__main__":
    main()