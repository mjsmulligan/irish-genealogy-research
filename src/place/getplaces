import requests
import csv
import time
import re
import sys

BASE_URL = "https://www.logainm.ie/api/v1.1/" 
API_KEY = "82NcXbOC6qF6xkRf0eQiNaJe4UqI0W"

DED_CATEGORY_ID = "ED" 
TOWNLAND_CATEGORY_ID = "BF"

def safe_get(data_dict, target_key, default_value=None):
    """Safely retrieves a value from a dictionary ignoring case sensitivity."""
    if not isinstance(data_dict, dict):
        return default_value
    for k, v in data_dict.items():
        if k.lower() == target_key.lower():
            return v
    return default_value

def get_name(place_data):
    """Extracts the best available English name from a Logainm place object."""
    name_en = safe_get(place_data, "nameEN") or safe_get(place_data, "defaultName")
    
    if not name_en:
        placenames = safe_get(place_data, "placenames", [])
        for pn in placenames:
            wording = safe_get(pn, "wording", "")
            language = safe_get(pn, "language", "")
            if language == "en" and wording:
                name_en = wording
                break
                
        if not name_en and placenames:
            name_en = safe_get(placenames[0], "wording", "")
            
    return name_en

def extract_geography(place_data):
    """Extracts the primary latitude and longitude coordinates."""
    geo = safe_get(place_data, "geography", {})
    coords = safe_get(geo, "coordinates", [])
    
    if isinstance(coords, list) and len(coords) > 0:
        coords = coords[0]
        
    lat = safe_get(coords, "latitude", "")
    lon = safe_get(coords, "longitude", "")
    
    return lat, lon

def extract_relationships(place_data):
    """Extracts County, Barony, and Civil Parish from the 'includedIn' array."""
    county, barony, parish = "", "", ""
    included_in = safe_get(place_data, "includedIn", [])
    
    for item in included_in:
        category = safe_get(item, "category", {})
        cat_id = safe_get(category, "id", "")
            
        if cat_id:
            cat_id = str(cat_id).upper()
            if cat_id == "CON":
                county = get_name(item)
            elif cat_id == "BAR":
                barony = get_name(item)
            elif cat_id == "PAR":
                parish = get_name(item)
            
    return county, barony, parish

def get_place_details(session, place_id):
    """Fetches the full data profile for a specific Logainm ID."""
    endpoint = f"{BASE_URL}{place_id}"
    response = session.get(endpoint)
    response.raise_for_status()
    return response.json()

def get_ded_search(session, search_term):
    """Locates the DED by exact ID or text query."""
    if search_term.isdigit():
        return get_place_details(session, search_term)
    
    params = {
        "Query": search_term,
        "CategoryID": DED_CATEGORY_ID 
    }
    response = session.get(BASE_URL, params=params)
    response.raise_for_status()
    
    results = safe_get(response.json(), "results", [])
    if not results:
        return None
        
    return get_place_details(session, safe_get(results[0], "id"))

def get_townland_summaries(session, ded_id):
    """Paginates through the API to collect all child townlands for a DED."""
    params = {
        "PlaceID": ded_id, 
        "CategoryID": TOWNLAND_CATEGORY_ID,
        "Page": 1
    }
    townlands = []
    
    while True:
        response = session.get(BASE_URL, params=params)
        response.raise_for_status()
        
        results = safe_get(response.json(), "results", [])
        if not results:
            break
            
        townlands.extend(results)
        if len(results) < 1000: 
            break
            
        params["Page"] += 1
        
    return townlands

def main():
    search_term = input("Enter the DED Name or Logainm Place ID: ").strip()
    
    if not search_term:
        print("No input provided. Exiting.")
        sys.exit(0)
        
    print(f"\nSearching for DED: {search_term}")
    
    # Use a requests Session for connection pooling (significantly faster multi-requests)
    with requests.Session() as session:
        session.headers.update({
            "Accept": "application/json",
            "X-Api-Key": API_KEY
        })
        
        try:
            ded_info = get_ded_search(session, search_term)
            
            if not ded_info:
                print("Electoral Division not found in Logainm.")
                sys.exit(0)
                
            ded_id = safe_get(ded_info, "id")
            ded_name_en = get_name(ded_info)
            display_name = ded_name_en if ded_name_en else search_term
                
            print(f"Found DED: {display_name} (ID: {ded_id})")
            
            print("Retrieving townland list...")
            townland_summaries = get_townland_summaries(session, ded_id)
            total_townlands = len(townland_summaries)
            print(f"Total townlands found: {total_townlands}")
            
            # Sanitize filename (removes invalid file characters)
            safe_filename = re.sub(r'[^\w\-_\. ]', '_', display_name)
            csv_filepath = f"{safe_filename}_townlands.csv"
            
            print(f"\nDownloading full data and writing to {csv_filepath}...")
            
            with open(csv_filepath, mode='w', newline='', encoding='utf-8-sig') as csv_file:
                writer = csv.writer(csv_file)
                
                # Write standard headers
                writer.writerow([
                    "place_id", "logainm_id", "name_en", "place_type", 
                    "county", "barony", "civil_parish", 
                    "latitude", "longitude", 
                    "logainm_url", "notes"
                ])
                
                place_id_counter = 1
                
                # Write DED Row
                d_lat, d_lon = extract_geography(ded_info)
                d_county, d_barony, d_parish = extract_relationships(ded_info)
                ded_url = f"https://www.logainm.ie/en/{ded_id}" if ded_id else ""
                
                writer.writerow([
                    place_id_counter, ded_id, ded_name_en, "ded", 
                    d_county, d_barony, d_parish,
                    d_lat, d_lon, 
                    ded_url, ""
                ])
                place_id_counter += 1
                
                # Write Townland Rows
                for index, t_summary in enumerate(townland_summaries, start=1):
                    t_id = safe_get(t_summary, "id")
                    
                    print(f"Processing {index}/{total_townlands} (ID: {t_id})...", end="\r")
                    t_info = get_place_details(session, t_id)
                    
                    t_name_en = get_name(t_info)
                    t_lat, t_lon = extract_geography(t_info)
                    t_county, t_barony, t_parish = extract_relationships(t_info)
                    t_url = f"https://www.logainm.ie/en/{t_id}" if t_id else ""
                    
                    writer.writerow([
                        place_id_counter, t_id, t_name_en, "townland", 
                        t_county, t_barony, t_parish,
                        t_lat, t_lon, 
                        t_url, ""
                    ])
                    place_id_counter += 1
                    
                    # Prevent aggressive rate limiting
                    time.sleep(0.05) 
                    
            print(f"\nExport complete. File saved to: {csv_filepath}")

        except PermissionError:
            print("\nPermission Error: Ensure you have write access to the current directory.")
        except requests.exceptions.RequestException as e:
            print(f"\nAPI request failed: {e}")
        except Exception as e:
            print(f"\nAn error occurred: {e}")

if __name__ == "__main__":
    main()